# MySQL (default)
DATABASE_URL=mysql+asyncmy://root:password@localhost:3306/novel_manager

# Or SQLite for quick dev:
# DATABASE_URL=sqlite+aiosqlite:///./novel_manager.db

# Database pool (MySQL)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# Auth
SECRET_KEY=change-me-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
